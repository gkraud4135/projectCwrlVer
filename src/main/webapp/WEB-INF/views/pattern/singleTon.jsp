<script>
    const SingleTon = (function() {
        let instance;

        const App = (function() {
            const App = function() {
                this.save = save;
            };

            const save = function(url, data) {
                return new Promise(function(resolve) {
                    const valid = validate(data);
                    if (!valid.validCheck) {
                        alert();
                        return;
                    }

                    const confirmMessage = '<spring:message code="regist.confirm" />';
                    getConfirm(confirmMessage, function(tf) {
                        if (!tf) return;
                        const successMessage = '<spring:message code="create.result.success"/>';
                        const ajaxLoader = new AjaxLoader();
                        ajaxLoader.setUrl(url)
                            .setData(data)
                            .setContent('JSON')
                            .setLoading(true)
                            .setCallbck(function(result) {
                                if(result.message){
                                    getAlert(result.message);
                                    return;
                                } else {
                                    getAlert(successMessage);
                                    resolve();
                                }
                            })
                            .execute();
                    });
                });
            };

            /* 유효성 검사*/
            const validate = function(data) {
                let validCheck = false;
                let message = '';

                if(data.valid){
                    validCheck = true;
                } else {
                    message += getMessage(data.state) + '<br>';
                }

                return {
                    validCheck: validCheck,
                    message: message
                };

            };

            /*유료성 검사시 에러코드 반환*/
            const getMessage = function(key) {
                const message = {
                    first: 'first error situation',
                    second: 'second error situation',
                };
                return message[key];
            }

            return App;
        })();


        return {
            getInstance: function() {
                if (!instance) {
                    instance = new App();
                }
                return instance;
            }
        };
    })();

    const fnSingleTon = function () {

        const pageGroupReg = SingleTon.getInstance();
        pageGroupReg.save('/piglet/insertGroupReg.do', self.pageGroupView.requestGenerate())
            .then(function(name) {
                if (name) {
                    self.pageGroupView.focus(name);
                    return;
                }
                fnSearch(1);
                const leftApp = LeftApp.getInstance();
                leftApp.search(leftApp);
                self.pageGroupView.resetList(self.pageGroupView);
            });

    }


</script>